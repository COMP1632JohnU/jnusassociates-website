{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "commitMsg",
      "type": "promptString",
      "description": "Commit message for deploy.sh",
      "default": "Update homepage"
    }
  ],
  "tasks": [
    {
      "label": "JNUS: Deploy Website",
      "type": "shell",
      "command": "bash",
      "args": ["./deploy.sh", "${input:commitMsg}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}